generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Paciente {
  id               Int         @id @default(autoincrement())
  nome             String
  cpf              String      @unique
  telefone         String?
  dataNascimento   DateTime?
  consultas        Consulta[]
}

model Especialidade {
  id       Int      @id @default(autoincrement())
  nome     String

  medicos  Medico[]
}

model Medico {
  id               Int              @id @default(autoincrement())
  nome             String
  crm              String           @unique
  telefone         String?

  especialidadeId  Int
  especialidade    Especialidade    @relation(fields: [especialidadeId], references: [id])

  consultas        Consulta[]
}

model Usuario {
  id         Int         @id @default(autoincrement())
  nome       String
  email      String      @unique
  senha      String

  consultas  Consulta[]
}

model Consulta {
  id           Int              @id @default(autoincrement())

  dataHora     DateTime
  valor        Float
  observacao   String?

  status       StatusConsulta   @default(AGENDADA)

  pacienteId   Int
  medicoId     Int
  usuarioId    Int

  paciente     Paciente         @relation(fields: [pacienteId], references: [id])

  medico       Medico           @relation(fields: [medicoId], references: [id])

  usuario      Usuario          @relation(fields: [usuarioId], references: [id])
}

enum StatusConsulta {
  AGENDADA
  FINALIZADA
  CANCELADA
}